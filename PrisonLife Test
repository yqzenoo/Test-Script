ESPFolder.Name = "BlueBerry_ESP_Storage"

local function createESP(player)
    local function applyESP(character)
        if player == LocalPlayer then return end
        character:WaitForChild("HumanoidRootPart", 5)
        character:WaitForChild("Humanoid", 5)

        if ESPFolder:FindFirstChild(player.Name) then
            ESPFolder[player.Name]:Destroy()
        end

        local container = Instance.new("Folder", ESPFolder)
        container.Name = player.Name

        local highlight = Instance.new("Highlight")
        highlight.Name = "Cham"
        highlight.Adornee = character
        highlight.FillColor = Color3.fromRGB(0, 110, 255)
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0.2
        highlight.Enabled = false
        highlight.Parent = container

        local billboard = Instance.new("BillboardGui")
        billboard.Name = "Tag"
        billboard.Adornee = character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
        billboard.Size = UDim2.new(0, 200, 0, 50)
        billboard.StudsOffset = Vector3.new(0, 2.5, 0)
        billboard.AlwaysOnTop = true
        billboard.Enabled = false
        billboard.Parent = container

        local layout = Instance.new("UIListLayout", billboard)
        layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        layout.SortOrder = Enum.SortOrder.LayoutOrder

        local nameLabel = Instance.new("TextLabel", billboard)
        nameLabel.Size = UDim2.new(1, 0, 0, 20)
        nameLabel.BackgroundTransparency = 1
        nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        nameLabel.TextStrokeTransparency = 0
        nameLabel.Font = Enum.Font.SourceSansBold
        nameLabel.TextSize = 14
        nameLabel.Text = player.Name
        nameLabel.Visible = false

        local healthLabel = Instance.new("TextLabel", billboard)
        healthLabel.Size = UDim2.new(1, 0, 0, 15)
        healthLabel.BackgroundTransparency = 1
        healthLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
        healthLabel.TextStrokeTransparency = 0
        healthLabel.Font = Enum.Font.SourceSansBold
        healthLabel.TextSize = 12
        healthLabel.Visible = false

        local hpConnection
        local function updateHP(health)
            healthLabel.Text = "HP: " .. math.floor(health)
        end
        if character:FindFirstChild("Humanoid") then
            hpConnection = character.Humanoid.HealthChanged:Connect(updateHP)
            updateHP(character.Humanoid.Health)
        end

        -- Render loop for ESP visibility
        local loop
        loop = RunService.RenderStepped:Connect(function()
            if not player.Parent or not character.Parent or not container.Parent then
                if hpConnection then hpConnection:Disconnect() end
                loop:Disconnect()
                container:Destroy()
                return
            end

            local teamMatch = true
            if Settings.ESP.TeamCheck and player.Team == LocalPlayer.Team and LocalPlayer.Team ~= nil then
                teamMatch = false
            end

            local overallActive = Settings.ESP.Enabled and teamMatch
            highlight.Enabled = overallActive and Settings.ESP.Chams
            billboard.Enabled = overallActive and (Settings.ESP.Names or Settings.ESP.Health)
            nameLabel.Visible = Settings.ESP.Names
            healthLabel.Visible = Settings.ESP.Health
        end)
    end

    if player.Character then
        applyESP(player.Character)
    end
    player.CharacterAdded:Connect(applyESP)
end

for _, p in pairs(Players:GetPlayers()) do
