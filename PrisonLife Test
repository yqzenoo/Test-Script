        local Character = LocalPlayer.Character
        if Character and Character:FindFirstChildOfClass("Humanoid") then
            Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
        end
    end
end)

local oldnamecall
oldnamecall = hookmetamethod(game, "__namecall", newcclosure(function(...)
    local method = getnamecallmethod()
    local args = { ... }
    local self = args[1]

    if self == Workspace and not checkcaller() and method == "Raycast" then
        local hitpart = closesthitpart

        if Settings.SilentAim and hitpart then
            local origin = args[2]
            local direction = getdirection(origin, hitpart.Position) * 1000
            args[2], args[3] = origin, direction
            return oldnamecall(unpack(args))
        end
    end
    return oldnamecall(...)
end))


