local function getdirection(origin, position)
    return (position - origin).Unit
end

local function isvisible(targetpart)
    local character = LocalPlayer.Character
    if not character then return false end

    local origin = camera.CFrame.Position
    local direction = (targetpart.Position - origin)

    local raycastparams = RaycastParams.new()
    raycastparams.FilterType = Enum.RaycastFilterType.Exclude
    raycastparams.FilterDescendantsInstances = { character, camera }
    raycastparams.IgnoreWater = true

    local result = Workspace:Raycast(origin, direction, raycastparams)
    if result then
        return result.Instance:IsDescendantOf(targetpart.Parent)
    end
    return true
end

local function issameteam(player)
    if not Settings.TeamCheck then return false end
    if LocalPlayer.Team == nil or player.Team == nil then return false end
    return LocalPlayer.Team == player.Team
end

local function getclosestplayer()
    local closestpart = nil
    local closestdistance = math.huge
    local mousepos = UserInputService:GetMouseLocation()

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            if Settings.TeamCheck and issameteam(player) then continue end

            local humanoidrootpart = player.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = player.Character:FindFirstChild("Humanoid")

            if humanoidrootpart and humanoid and humanoid.Health > 0 then
                local screenpos, onscreen = camera:WorldToViewportPoint(humanoidrootpart.Position)

                if onscreen then
                    if Settings.VisibleCheck and not isvisible(humanoidrootpart) then continue end

                    local distance = (Vector2.new(screenpos.X, screenpos.Y) - mousepos).Magnitude

                    if Settings.FOV.Enabled and distance > Settings.FOV.Radius then continue end

                    if distance < closestdistance then
                        closestdistance = distance
                        closestpart = humanoidrootpart
                    end
                end
            end
        end
    end
    return closestpart
end

local closesthitpart = nil


local function aimAt(targetPart)
    if not targetPart or not camera then return end
    
    local head = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head")
    if not head then return end
    
    -- Calculate look direction
    local aimPosition = targetPart.Position
    local cameraPosition = camera.CFrame.Position
    
    -- Create CFrame looking at target
    local lookCFrame = CFrame.lookAt(cameraPosition, aimPosition)
    
    -- Smooth interpolation
    local smoothness = math.max(Settings.AimbotSmoothness, 0.1)
    local alpha = 1 / smoothness
    
    camera.CFrame = camera.CFrame:Lerp(lookCFrame, alpha)
end


RunService.Heartbeat:Connect(function()
    closesthitpart = (Settings.SilentAim or Settings.Aimbot) and getclosestplayer() or nil

    if Settings.FOV.Enabled then
        FOVCircle.Visible = true
        FOVCircle.Position = UserInputService:GetMouseLocation()
        FOVCircle.Radius = Settings.FOV.Radius
        FOVCircle.Color = Settings.FOV.Color
    else
        FOVCircle.Visible = false
    end

    -- Aimbot - works on BOTH mobile and PC
    if Settings.Aimbot and closesthitpart then
        local shouldAim = false

        if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            shouldAim = true
        end

        -- Mobile: Touch detected OR MobileAimLock enabled
        if Settings.MobileAimLock then
            local touches = UserInputService:GetTouchInputs()
            if UserInputService.TouchEnabled or #touches > 0 then
                shouldAim = true
            end
        end

        if shouldAim then
            local screenpos, onscreen = camera:WorldToViewportPoint(closesthitpart.Position)
            if onscreen then
                aimAt(closesthitpart)
            end
        end
    end
end)

UserInputService.JumpRequest:Connect(function()
